# Local Supabase during development:
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Needed for seeded tests and admin helpers:
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google OAuth for local Supabase Auth (used by [auth.external.google] in supabase/config.toml)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_google_oauth_client_id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your_google_oauth_client_secret

# For production / Vercel, replace the two PUBLIC_* values with your hosted Supabase project values.
